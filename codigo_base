  },
  {
    id: 4, name: "Eucrates", x: 25, y: 75, color: "bg-purple-400",
    image: "https://via.placeholder.com/150/aa88ff/ffffff?text=Eucrates", // REEMPLAZAR URL
    dialogues: [
