    ],
    options: [
      { text: "Denunciarlo por violar el procedimiento legal. (Respeto a la Ley/Nómos)", points: 1000, feedback: "¡Bien! En Atenas, la 'Graphe Paranomon' castigaba a quien propusiera leyes ilegales, incluso si eran populares." },
      { text: "Ignorarlo, el resultado final fue bueno. (Pragmatismo)", points: 100, feedback: "Esto debilita el estado de derecho, base de la democracia ateniense." },
      { text: "Pedir que se cree una nueva comisión para investigar. (Burocracia)", points: 600, feedback: "Es una opción, pero la justicia ateniense requería acción ciudadana directa." }
